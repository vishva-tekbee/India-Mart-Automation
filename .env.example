# MongoDB (Atlas cloud — replace with your connection string)
# Get yours at: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=indiamart_leads

# Scraper
SCRAPE_INTERVAL=5
MAX_RESULTS=500

# API
PORT=8000
API_KEY=change-me-to-a-secret-key

# Filter criteria
MIN_QTY_KG=100
REQUIRE_GST=true
MIN_LONGEVITY_YEARS=1
OMITTED_STATES=tamil nadu,west bengal,andhra pradesh,odisha,orissa
